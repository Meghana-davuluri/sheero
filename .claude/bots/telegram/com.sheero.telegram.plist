<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.telegram</string>

    <key>WorkingDirectory</key>
    <string>~/sheero</string>

    <key>ProgramArguments</key>
    <array>
        <string>~/sheero/.claude/bots/telegram/.venv/bin/python</string>
        <string>~/sheero/.claude/bots/telegram/bot.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>~/Library/Logs/sheero-telegram.log</string>
    <key>StandardErrorPath</key>
    <string>~/Library/Logs/sheero-telegram.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>~</string>
    </dict>
</dict>
</plist>
